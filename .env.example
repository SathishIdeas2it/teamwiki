# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://teamwiki:password@localhost:5432/teamwiki?schema=public"
DATABASE_URL_TEST="postgresql://teamwiki:password@localhost:5432/teamwiki_test?schema=public"

# ─── NextAuth / Auth.js ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32 (must be at least 64 characters)
NEXTAUTH_SECRET="replace-with-64-char-hex-string-generated-via-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── MCP Filesystem Import ─────────────────────────────────────────────────────
# Absolute path to the directory monitored for document imports
IMPORT_DIR="/data/teamwiki-imports"
# Polling interval in milliseconds (minimum 10000)
IMPORT_POLL_INTERVAL_MS="60000"
# ID of the system service account used for MCP-imported articles (must exist in the database)
SYSTEM_USER_ID="system-service-account-id"

# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="info"
